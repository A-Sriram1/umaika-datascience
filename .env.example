# FactoryMind AI Platform Environment Configuration
# Copy this file to .env.local for local development or configure in Render.com Environment Variables

# Application Settings
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API & Telemetry Endpoints
NEXT_PUBLIC_API_BASE_URL=https://api.factorymind.ai
NEXT_PUBLIC_MQTT_BROKER_URL=mqtt://factory-iot.local:1883
NEXT_PUBLIC_KAFKA_STREAM_URL=kafka://data-pipeline:9092

# Feature Flags
NEXT_PUBLIC_ENABLE_SIMULATION_MODE=true
NEXT_PUBLIC_ENABLE_ANALYTICS=true
